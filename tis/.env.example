# Connect IT - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# MySQL Database Configuration
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=connectit_db

# ============================================
# Gemini AI API Key (Optional)
# ============================================
GEMINI_API_KEY=AIzaSyD7X-NZaDxd_J381on_io8Tvx1LTMDyRqk

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# ============================================
# Server Configuration
# ============================================
PORT=3000

# ============================================
# Firebase Configuration (Legacy - for migration only)
# ============================================
# These are only needed for running the migration script
# After migration is complete, these can be removed
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_DATABASE_ID=your_firestore_database_id

# ============================================
# Email Configuration (Legacy Fallback Mailbox)
# ============================================
# Company Email: Support@technosprint.net

# SMTP (Outgoing Emails - Replies, Notifications)
SMTP_HOST=mail.technosprint.net
SMTP_PORT=465
SMTP_USER=Support@technosprint.net
SMTP_PASS=your_smtp_password_here
SMTP_ENCRYPTION=TLS

# IMAP (Incoming Emails - Automatic Ticket Creation)
IMAP_HOST=mail.technosprint.net
IMAP_PORT=993
IMAP_USER=Support@technosprint.net
IMAP_PASS=your_imap_password_here
IMAP_ENCRYPTION=TLS

# ============================================
# Microsoft 365 Domain Email Integration
# Provider: Microsoft 365 | Domain: technosprint.net
# Mailbox: support@technosprint.net
# ============================================

# M365 Incoming Mail (IMAP / SSL-TLS)
M365_IMAP_HOST=outlook.office365.com
M365_IMAP_PORT=993
M365_IMAP_USER=support@technosprint.net
M365_IMAP_PASS=your_m365_password_here
M365_IMAP_ENCRYPTION=SSL

# M365 Outgoing Mail (SMTP / STARTTLS)
M365_SMTP_HOST=smtp.office365.com
M365_SMTP_PORT=587
M365_SMTP_USER=support@technosprint.net
M365_SMTP_PASS=your_m365_password_here
M365_SMTP_ENCRYPTION=STARTTLS

# M365 Integration Control
# Set to 'true' to auto-seed the M365 config into company_email_configs on startup
M365_AUTO_SEED=true
# Set to 'true' to use M365 as the default config (replaces fallback)
M365_IS_DEFAULT=true


# ============================================
# Session/JWT Configuration
# ============================================
JWT_SECRET=ConnectIT_2026_Secure_JWT_Key_987654321
SESSION_TIMEOUT=86400

# ============================================
# PHP Backend Configuration (for timesheet module)
# ============================================
# Timesheet uses its own database configuration
# Set these for MySQL or leave empty for SQLite fallback
DB_HOST=localhost
DB_NAME=timesheet_db
DB_USER=root
DB_PASS=your_mysql_password
